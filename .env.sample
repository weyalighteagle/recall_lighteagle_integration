GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/calendar/oauth/callback

OUTLOOK_OAUTH_CLIENT_ID=YOUR_OUTLOOK_OAUTH_CLIENT_ID
OUTLOOK_OAUTH_CLIENT_SECRET=YOUR_OUTLOOK_OAUTH_CLIENT_SECRET
OUTLOOK_OAUTH_REDIRECT_URI=https://YOUR_RAILWAY_URL/api/calendar/oauth/callback

RECALL_API_KEY=YOUR_RECALL_API_KEY
RECALL_REGION=eu-central-1 # e.g. us-west-2, us-east-1, eu-central-1, ap-northeast-1

# ─── Recall Webhook Signature Verification (LIG-81) ──────────
# Workspace Verification Secret from Recall (Svix-style, starts with whsec_).
# Used to verify webhook-id / webhook-timestamp / webhook-signature on the Recall routes.
RECALL_WEBHOOK_SECRET=whsec_YOUR_RECALL_WORKSPACE_SECRET
# Reserved for the legacy Recall dashboard webhook endpoint; leave blank unless used.
RECALL_SVIX_WEBHOOK_SECRET=
# Monitor mode by default (verify + log, never block). Set to "true" to REJECT
# invalid/unsigned Recall webhooks with 401. Anything other than "true" = monitor mode.
RECALL_WEBHOOK_ENFORCE=false

# Railway domain (without protocol)
RAILWAY_DOMAIN=YOUR_APP.up.railway.app

# Production backend URL (Railway)
RAILWAY_URL=https://YOUR_APP.up.railway.app

# Production frontend URL (Vercel)
VERCEL_URL=https://YOUR_APP.vercel.app

# ─── Voice Agent ────────────────────────────────────────────
# Bot'un kamerasında gösterilecek Output Media web sayfası.
# Recall'ın demo sayfasını kullanabilirsiniz: https://recallai-demo.netlify.app
# Veya voice-agent-demo/client build'ini kendi hosting'inize deploy edin.
VOICE_AGENT_PAGE_URL=https://recallai-demo.netlify.app

# OpenAI Realtime relay server WSS adresi.
# voice-agent-demo/node-server'ı Railway'de deploy edip URL'ini buraya yazın.
VOICE_AGENT_WSS_URL=wss://YOUR_RELAY_SERVER.up.railway.app

# Railway backend URL exposed to the Vite frontend. Used to start the calendar OAuth
# flow directly on the Railway domain so the CSRF nonce cookie is readable on the
# Railway callback (LIG-80). Must be set in Vercel project env per environment.
VITE_RAILWAY_API_URL=https://recalllighteagleintegration-production.up.railway.app

# ─── Clerk Auth ──────────────────────────────────────────────
# Publishable key used by the Vite frontend (must start with pk_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# Publishable key used by the backend (same value as above)
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# Secret key used by the backend to verify Clerk JWTs (must start with sk_)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY

# ─── Gladia ──────────────────────────────────────────────────
GLADIA_API_KEY=your_gladia_key_here